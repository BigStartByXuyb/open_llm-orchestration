# Copy this file to .env and fill in your values
# Vite exposes VITE_* vars to the browser

# Backend URL (default: proxy through Vite dev server)
VITE_API_BASE_URL=/api
VITE_WS_BASE_URL=ws://localhost:8000

# Test JWT token — generate with the backend:
#   python -c "
#   from orchestration.gateway.middleware.auth import create_access_token
#   print(create_access_token({'sub': 'dev-user', 'tenant_id': 'dev-tenant'}, secret='your-secret'))
#   "
VITE_DEV_JWT_TOKEN=
