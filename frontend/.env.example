# Backend proxy target port for `npm run dev` (default: 8001 = docker-compose)
# Set to 8000 when running uvicorn directly: BACKEND_PORT=8000 npm run dev
BACKEND_PORT=8001

# Override full API base URL (bypasses Vite proxy entirely)
# VITE_API_BASE_URL=http://localhost:8001

# Override WebSocket base URL (docker-compose default)
VITE_WS_BASE_URL=ws://localhost:8001
# For uvicorn direct: VITE_WS_BASE_URL=ws://localhost:8000
