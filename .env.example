# ─────────────────────────────────────────────────────────────────────────────
# LLM Orchestration Platform — .env.example
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All ORCH_* variables are read by pydantic-settings (prefix: ORCH_).
# Variables WITHOUT the ORCH_ prefix are used only by docker-compose.yml.
# ─────────────────────────────────────────────────────────────────────────────


# ─── Docker-compose postgres service ─────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=llm_orchestration


# ─── Auth ─────────────────────────────────────────────────────────────────────
# REQUIRED in production — must be a long random secret.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ORCH_JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION

ORCH_JWT_ALGORITHM=HS256
ORCH_JWT_EXPIRE_MINUTES=60


# ─── Database ─────────────────────────────────────────────────────────────────
# When using docker-compose the app service overrides this automatically.
# For local dev (without Docker), point to your local Postgres instance.
ORCH_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/llm_orchestration
ORCH_DATABASE_POOL_SIZE=10
ORCH_DATABASE_MAX_OVERFLOW=20


# ─── Redis ────────────────────────────────────────────────────────────────────
ORCH_REDIS_URL=redis://localhost:6379/0


# ─── Rate limiting ────────────────────────────────────────────────────────────
ORCH_RATE_LIMIT_REQUESTS_PER_MINUTE=60


# ─── Coordinator LLM ──────────────────────────────────────────────────────────
ORCH_COORDINATOR_MODEL=claude-sonnet-4-6


# ─── Provider API keys ────────────────────────────────────────────────────────
# Fill in only the providers you intend to use.
ORCH_ANTHROPIC_API_KEY=
ORCH_OPENAI_API_KEY=
ORCH_DEEPSEEK_API_KEY=
ORCH_GEMINI_API_KEY=
ORCH_JIMENG_API_KEY=
ORCH_KLING_API_KEY=


# ─── Context truncation ───────────────────────────────────────────────────────
ORCH_CONTEXT_TRUNCATION_THRESHOLD=400000
ORCH_MAX_SUBTASK_CONTEXT_CHARS=40000
ORCH_MAX_RESULT_CHARS_PER_BLOCK=8000
ORCH_MAX_SUMMARY_INPUT_CHARS=120000


# ─── Provider concurrency limits ─────────────────────────────────────────────
# JSON object mapping provider name → max concurrent requests.
ORCH_PROVIDER_CONCURRENCY_LIMITS={"anthropic":5,"openai":10,"deepseek":8,"gemini":5,"jimeng":3,"kling":2}


# ─── Feature flags ────────────────────────────────────────────────────────────
ORCH_ENABLE_REVIEW_GATE=false


# ─── Observability (OpenTelemetry) ────────────────────────────────────────────
# Leave empty to disable OTLP export.
ORCH_OTEL_EXPORTER_OTLP_ENDPOINT=


# ─── Webhooks ─────────────────────────────────────────────────────────────────
# Leave empty to skip webhook signature verification.
ORCH_WEBHOOK_SECRET=


# ─── RAG ──────────────────────────────────────────────────────────────────────
# Set to 0 to disable RAG retrieval entirely.
ORCH_RAG_TOP_K=5


# ─── Docker sandbox code execution (MCP) ─────────────────────────────────────
# Leave empty to disable the Docker-based code execution sandbox.
ORCH_DOCKER_EXEC_MCP_IMAGE=
ORCH_DOCKER_EXEC_MEMORY_LIMIT=256m
ORCH_DOCKER_EXEC_CPU_LIMIT=0.5


# ─── MCP server connections ───────────────────────────────────────────────────
# JSON array of MCP server configs. Leave empty for no external MCP servers.
# Example: [{"server_id":"my_mcp","transport":"stdio","command":"npx","args":["my-mcp-server"]}]
ORCH_MCP_SERVER_CONFIGS=[]


# ─── Jimeng authentication mode ───────────────────────────────────────────────
# "bearer" (default) uses JIMENG_API_KEY as a Bearer token.
# "volcano_signing" uses HMAC-SHA256 signing (requires ACCESS_KEY + SECRET_KEY).
ORCH_JIMENG_AUTH_MODE=bearer
ORCH_JIMENG_ACCESS_KEY=
ORCH_JIMENG_SECRET_KEY=
